{% comment %}
  Section: Inner Banner
  File: sections/inner-banner.liquid
  Page-level banner used on inner pages (About, How it works, etc.).
  Sits inside a 1280px container with white outer padding (Figma "Header / 98").
{% endcomment %}

{%- liquid
  assign bg_url = ''
  if section.settings.background_image != blank
    assign bg_url = section.settings.background_image | image_url: width: 2000
  endif
  assign pad_top = section.settings.padding_top | default: 80
  assign pad_bottom = section.settings.padding_bottom | default: 80
  assign pad_x = section.settings.padding_x | default: 64
  assign margin_top = section.settings.margin_top | default: 0
  assign margin_bottom = section.settings.margin_bottom | default: 0
-%}

<section class="inner-banner" style="
  --ib-bg: {{ section.settings.background_color | default: '#ffffff' }};
  --ib-card-fallback: {{ section.settings.card_fallback_color | default: '#8a8a8a' }};
  --ib-overlay-color: {{ section.settings.overlay_color | default: '#000000' }};
  --ib-overlay-alpha: {{ section.settings.overlay_opacity | default: 40 | times: 0.01 }};
  --ib-heading-color: {{ section.settings.heading_color | default: '#ffffff' }};
  --ib-text-color: {{ section.settings.text_color | default: '#ffffff' }};
  --ib-primary-bg: {{ section.settings.primary_btn_bg | default: '#ffffff' }};
  --ib-primary-text: {{ section.settings.primary_btn_text | default: '#000000' }};
  --ib-primary-border: {{ section.settings.primary_btn_border | default: '#ffffff' }};
  --ib-secondary-bg: {{ section.settings.secondary_btn_bg | default: 'transparent' }};
  --ib-secondary-text: {{ section.settings.secondary_btn_text | default: '#ffffff' }};
  --ib-secondary-border: {{ section.settings.secondary_btn_border | default: '#ffffff' }};
  background: var(--ib-bg, #fff);
  padding: {{ pad_top }}px {{ pad_x }}px {{ pad_bottom }}px;
  margin: {{ margin_top }}px 0 {{ margin_bottom }}px;
">
  <div class="inner-banner-container">
    <div class="inner-banner-card" {% if bg_url != blank %}style="background-image: url('{{ bg_url }}');"{% endif %}>
      <div class="inner-banner-overlay" aria-hidden="true"></div>
      <div class="inner-banner-inner">
        <div class="inner-banner-content">
          {%- if section.settings.show_heading -%}
            {%- if section.settings.heading != blank -%}
              <h1 class="inner-banner-heading" data-reveal data-reveal-delay="100">{{ section.settings.heading }}</h1>
            {%- endif -%}
          {%- endif -%}

          {%- if section.settings.show_description -%}
            {%- if section.settings.description != blank -%}
              <div class="inner-banner-text" data-reveal data-reveal-delay="200">{{ section.settings.description }}</div>
            {%- endif -%}
          {%- endif -%}

          {%- if section.settings.show_primary_cta or section.settings.show_secondary_cta -%}
            <div class="inner-banner-actions" data-reveal data-reveal-delay="300">
              {%- if section.settings.show_primary_cta -%}
                {%- if section.settings.primary_cta_text != blank -%}
                  <a href="{{ section.settings.primary_cta_link | default: '#' }}" class="inner-banner-btn inner-banner-btn--primary">
                    {{ section.settings.primary_cta_text }}
                  </a>
                {%- endif -%}
              {%- endif -%}
              {%- if section.settings.show_secondary_cta -%}
                {%- if section.settings.secondary_cta_text != blank -%}
                  <a href="{{ section.settings.secondary_cta_link | default: '#' }}" class="inner-banner-btn inner-banner-btn--secondary">
                    {{ section.settings.secondary_cta_text }}
                  </a>
                {%- endif -%}
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Inner Banner",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Your baby deserves the best. Your insurance should cover it.</p>" },
    { "type": "richtext", "id": "description", "label": "Description", "default": "<p>Not sure what your plan covers? We'll figure it out for you, then ship the maternity products you need, direct to your door.</p>" },

    { "type": "header", "content": "Show / hide elements" },
    { "type": "checkbox", "id": "show_heading", "label": "Show heading", "default": true },
    { "type": "checkbox", "id": "show_description", "label": "Show description", "default": true },
    { "type": "checkbox", "id": "show_primary_cta", "label": "Show primary button", "default": true },
    { "type": "checkbox", "id": "show_secondary_cta", "label": "Show secondary button", "default": true },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_x", "label": "Padding left / right", "min": 0, "max": 96, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "margin_top", "label": "Margin top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_bottom", "label": "Margin bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },

    { "type": "header", "content": "Background + overlay" },
    { "type": "color", "id": "background_color", "label": "Outer background", "default": "#ffffff" },
    { "type": "color", "id": "card_fallback_color", "label": "Card fallback (when no image)", "default": "#8a8a8a" },
    { "type": "color", "id": "overlay_color", "label": "Image overlay color", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "Image overlay opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 40 },

    { "type": "header", "content": "Text colors" },
    { "type": "color", "id": "heading_color", "label": "Heading", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Description", "default": "#ffffff" },

    { "type": "header", "content": "Primary CTA" },
    { "type": "text", "id": "primary_cta_text", "label": "Primary button text", "default": "Check" },
    { "type": "url", "id": "primary_cta_link", "label": "Primary button link" },
    { "type": "color", "id": "primary_btn_bg", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "primary_btn_text", "label": "Text", "default": "#000000" },
    { "type": "color", "id": "primary_btn_border", "label": "Border", "default": "#ffffff" },

    { "type": "header", "content": "Secondary CTA" },
    { "type": "text", "id": "secondary_cta_text", "label": "Secondary button text", "default": "Shop" },
    { "type": "url", "id": "secondary_cta_link", "label": "Secondary button link" },
    { "type": "color", "id": "secondary_btn_bg", "label": "Background (empty for transparent)" },
    { "type": "color", "id": "secondary_btn_text", "label": "Text", "default": "#ffffff" },
    { "type": "color", "id": "secondary_btn_border", "label": "Border", "default": "#ffffff" }
  ],
  "presets": [
    { "name": "Inner Banner" }
  ]
}
{% endschema %}
