{% comment %}
  Section: Image With Text
  File: sections/image-with-text.liquid
  Reusable for Experts / Providers / any side-by-side image+text block.
{% endcomment %}

{%- liquid
  assign section_class = 'experts-section'
  assign grid_class = 'experts-grid'
  assign image_class = 'experts-image'
  assign copy_class = 'experts-copy'

  if section.settings.style == 'providers'
    assign section_class = 'providers-section'
    assign grid_class = 'providers-grid'
    assign image_class = 'providers-image'
    assign copy_class = 'providers-copy'
  endif

  assign default_pad_top = 100
  if section.settings.style == 'providers'
    assign default_pad_top = 20
  endif
  assign pad_top = section.settings.padding_top | default: default_pad_top
  assign pad_bottom = section.settings.padding_bottom | default: 100
  assign pad_x = section.settings.padding_x | default: 0
  assign margin_top = section.settings.margin_top | default: 0
  assign margin_bottom = section.settings.margin_bottom | default: 0
-%}

<section class="{{ section_class }}" style="padding: {{ pad_top }}px {{ pad_x }}px {{ pad_bottom }}px; margin: {{ margin_top }}px 0 {{ margin_bottom }}px;">
  <div class="container {{ grid_class }}">
    {%- if section.settings.show_image and section.settings.image_position == 'left' -%}
      <div class="{{ image_class }}" data-reveal>
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag: alt: section.settings.heading, loading: 'lazy' }}
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="{{ copy_class }}">
      {%- if section.settings.show_eyebrow -%}
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow" data-reveal>{{ section.settings.eyebrow }}</p>
        {%- endif -%}
      {%- endif -%}
      {%- if section.settings.show_heading -%}
        {%- if section.settings.heading != blank -%}
          <h2 data-reveal data-reveal-delay="80">{{ section.settings.heading }}</h2>
        {%- endif -%}
      {%- endif -%}
      {%- if section.settings.show_description -%}
        {%- if section.settings.description != blank -%}
          <p data-reveal data-reveal-delay="160">{{ section.settings.description }}</p>
        {%- endif -%}
      {%- endif -%}

      {%- if section.settings.show_primary_cta or section.settings.show_secondary_cta -%}
        <div class="expert-buttons" data-reveal data-reveal-delay="220">
          {%- if section.settings.show_primary_cta -%}
            {%- if section.settings.primary_cta_text != blank -%}
              <a href="{{ section.settings.primary_cta_link | default: '#' }}" class="btn {{ section.settings.primary_cta_style | default: 'btn-primary' }}">
                {{ section.settings.primary_cta_text }}
              </a>
            {%- endif -%}
          {%- endif -%}

          {%- if section.settings.show_secondary_cta -%}
            {%- if section.settings.secondary_cta_text != blank -%}
              <a href="{{ section.settings.secondary_cta_link | default: '#' }}" class="link-arrow">
                {{ section.settings.secondary_cta_text }}
                {% render 'icon-arrow-right', size: 15, height: 16, color: 'black' %}
              </a>
            {%- endif -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.show_image and section.settings.image_position != 'left' -%}
      <div class="{{ image_class }}" data-reveal>
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag: alt: section.settings.heading, loading: 'lazy' }}
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Image With Text",
  "tag": "div",
  "settings": [
    {
      "type": "select",
      "id": "style",
      "label": "Section style",
      "options": [
        { "value": "experts", "label": "Experts (mint bg, full padding)" },
        { "value": "providers", "label": "Providers (mint bg, top padding reduced)" }
      ],
      "default": "experts"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "right"
    },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "richtext", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "description", "label": "Description" },

    { "type": "header", "content": "Show / hide elements" },
    { "type": "checkbox", "id": "show_image", "label": "Show image", "default": true },
    { "type": "checkbox", "id": "show_eyebrow", "label": "Show eyebrow", "default": true },
    { "type": "checkbox", "id": "show_heading", "label": "Show heading", "default": true },
    { "type": "checkbox", "id": "show_description", "label": "Show description", "default": true },
    { "type": "checkbox", "id": "show_primary_cta", "label": "Show primary button", "default": true },
    { "type": "checkbox", "id": "show_secondary_cta", "label": "Show secondary link", "default": true },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_x", "label": "Padding left / right", "min": 0, "max": 96, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_top", "label": "Margin top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_bottom", "label": "Margin bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },

    { "type": "header", "content": "Primary CTA" },
    { "type": "text", "id": "primary_cta_text", "label": "Primary button text" },
    { "type": "url", "id": "primary_cta_link", "label": "Primary button link" },
    {
      "type": "select",
      "id": "primary_cta_style",
      "label": "Primary button style",
      "options": [
        { "value": "btn-primary", "label": "Primary (pink)" },
        { "value": "btn-dark", "label": "Dark" },
        { "value": "btn-outline", "label": "Outline" }
      ],
      "default": "btn-primary"
    },

    { "type": "header", "content": "Secondary CTA (link arrow)" },
    { "type": "text", "id": "secondary_cta_text", "label": "Secondary link text" },
    { "type": "url", "id": "secondary_cta_link", "label": "Secondary link URL" }
  ],
  "presets": [
    {
      "name": "Image With Text"
    }
  ]
}
{% endschema %}
