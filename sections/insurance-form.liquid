{% comment %}
  Section: Insurance Form (lead-gen form for coverage verification)
  File: sections/insurance-form.liquid
  Figma: "CTA / 58"
  Uses Shopify's built-in {% form 'contact' %} — submissions go to the store's contact email.
  Note: Shopify's contact form does not store file uploads; the field is present but the file
  is not retained. Swap to a custom action (Klaviyo / Formspree / etc.) if uploads matter.
{% endcomment %}

{%- liquid
  assign pad_top = section.settings.padding_top | default: 112
  assign pad_bottom = section.settings.padding_bottom | default: 112
  assign pad_x = section.settings.padding_x | default: 64
  assign margin_top = section.settings.margin_top | default: 0
  assign margin_bottom = section.settings.margin_bottom | default: 0
-%}

<section class="ins-form-section" style="
  --if-bg: {{ section.settings.background_color | default: '#ffffff' }};
  --if-heading-color: {{ section.settings.heading_color | default: '#000000' }};
  --if-text-color: {{ section.settings.text_color | default: '#000000' }};
  --if-input-bg: {{ section.settings.input_bg | default: '#ffffff' }};
  --if-input-border: {{ section.settings.input_border | default: '#000000' }};
  --if-input-text: {{ section.settings.input_text | default: '#000000' }};
  --if-input-placeholder: {{ section.settings.input_placeholder_color | default: 'rgba(0,0,0,0.6)' }};
  --if-button-bg: {{ section.settings.button_bg | default: '#000000' }};
  --if-button-text: {{ section.settings.button_text_color | default: '#ffffff' }};
  --if-button-border: {{ section.settings.button_border | default: '#000000' }};
  --if-footnote-color: {{ section.settings.footnote_color | default: '#000000' }};
  background: var(--if-bg, #fff);
  padding: {{ pad_top }}px {{ pad_x }}px {{ pad_bottom }}px;
  margin: {{ margin_top }}px 0 {{ margin_bottom }}px;
">
  <div class="ins-form-container">
    <div class="ins-form-column">

      <div class="ins-form-content">
        {%- if section.settings.show_heading -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="ins-form-heading" data-reveal>{{ section.settings.heading }}</h2>
          {%- endif -%}
        {%- endif -%}
        {%- if section.settings.show_description -%}
          {%- if section.settings.description != blank -%}
            <div class="ins-form-desc" data-reveal data-reveal-delay="100">{{ section.settings.description }}</div>
          {%- endif -%}
        {%- endif -%}
      </div>

      {%- form 'contact', class: 'ins-form', enctype: 'multipart/form-data' -%}
        {%- if form.posted_successfully? -%}
          <div class="ins-form-success" role="status">
            {{ section.settings.success_message | default: "Thanks — we'll be in touch within 24 hours." }}
          </div>
        {%- elsif form.errors -%}
          <div class="ins-form-error" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <input type="hidden" name="contact[Form type]" value="Insurance verification">

        <div class="ins-form-field">
          <label for="ins-name" class="visually-hidden">Your First and Last Name</label>
          <input type="text" id="ins-name" name="contact[Name]" placeholder="Your First and Last Name*" required>
        </div>

        <div class="ins-form-field">
          <label for="ins-state" class="visually-hidden">State</label>
          <input type="text" id="ins-state" name="contact[State]" placeholder="State*" required>
        </div>

        <div class="ins-form-field">
          <label for="ins-plan" class="visually-hidden">Insurance plan name</label>
          <input type="text" id="ins-plan" name="contact[Insurance plan name]" placeholder="Insurance plan name*" required>
        </div>

        <div class="ins-form-field">
          <label for="ins-member" class="visually-hidden">Insurance member ID</label>
          <input type="text" id="ins-member" name="contact[Insurance member ID]" placeholder="Insurance member ID*" required>
        </div>

        <div class="ins-form-field">
          <label for="ins-phone" class="visually-hidden">Your phone number</label>
          <input type="tel" id="ins-phone" name="contact[phone]" placeholder="Your Phone Number*" required>
        </div>

        <div class="ins-form-field">
          <label for="ins-email" class="visually-hidden">Your email</label>
          <input type="email" id="ins-email" name="contact[email]" placeholder="Your Email*" required>
        </div>

        <div class="ins-form-field">
          <label for="ins-doc-name" class="visually-hidden">Doctor's name</label>
          <input type="text" id="ins-doc-name" name="contact[Doctor name]" placeholder="Doctor's Name">
        </div>

        <div class="ins-form-field">
          <label for="ins-doc-phone" class="visually-hidden">Doctor's phone number</label>
          <input type="tel" id="ins-doc-phone" name="contact[Doctor phone]" placeholder="Doctor's Phone Number">
        </div>

        <div class="ins-form-field ins-form-file">
          <input type="file" id="ins-prescription" name="contact[Prescription]" accept="image/*,.pdf">
          <label for="ins-prescription" class="ins-form-file-label">
            <span class="ins-form-file-text">Upload Prescription (Optional)</span>
            <span class="ins-form-file-btn">Browse</span>
          </label>
        </div>

        <button type="submit" class="ins-form-submit">
          {{ section.settings.button_text | default: 'Verify coverage' }}
        </button>
      {%- endform -%}

      {%- if section.settings.show_footnote -%}
        {%- if section.settings.footnote != blank -%}
          <div class="ins-form-footnote" data-reveal data-reveal-delay="300">
            {{ section.settings.footnote }}
          </div>
        {%- endif -%}
      {%- endif -%}

    </div>
  </div>
</section>

<script>
  (function () {
    var fileInput = document.getElementById('ins-prescription');
    if (!fileInput) return;
    var label = fileInput.nextElementSibling;
    if (!label) return;
    var text = label.querySelector('.ins-form-file-text');
    fileInput.addEventListener('change', function () {
      if (fileInput.files && fileInput.files.length) {
        text.textContent = fileInput.files[0].name;
        label.classList.add('has-file');
      } else {
        text.textContent = 'Upload Prescription (Optional)';
        label.classList.remove('has-file');
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Insurance Form",
  "tag": "section",
  "settings": [
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Less insurance hassle. More baby time.</p>" },
    { "type": "richtext", "id": "description", "label": "Description", "default": "<p>Enter your details and one of our team will check what your plan covers. You'll receive a personalized email within 24 hours detailing <strong>all the products you're covered for</strong>.</p>" },
    { "type": "text", "id": "button_text", "label": "Submit button text", "default": "Verify coverage" },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Thanks — we'll be in touch within 24 hours." },
    { "type": "richtext", "id": "footnote", "label": "Footnote", "default": "<p>Your information is secure and used only for insurance verification purposes.</p>" },

    { "type": "header", "content": "Show / hide elements" },
    { "type": "checkbox", "id": "show_heading", "label": "Show heading", "default": true },
    { "type": "checkbox", "id": "show_description", "label": "Show description", "default": true },
    { "type": "checkbox", "id": "show_footnote", "label": "Show footnote", "default": true },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 112 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 112 },
    { "type": "range", "id": "padding_x", "label": "Padding left / right", "min": 0, "max": 96, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "margin_top", "label": "Margin top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_bottom", "label": "Margin bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },

    { "type": "header", "content": "Section colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading", "default": "#000000" },
    { "type": "color", "id": "text_color", "label": "Description", "default": "#000000" },
    { "type": "color", "id": "footnote_color", "label": "Footnote", "default": "#000000" },

    { "type": "header", "content": "Form input colors" },
    { "type": "color", "id": "input_bg", "label": "Input background", "default": "#ffffff" },
    { "type": "color", "id": "input_border", "label": "Input border", "default": "#000000" },
    { "type": "color", "id": "input_text", "label": "Input text", "default": "#000000" },
    { "type": "color", "id": "input_placeholder_color", "label": "Placeholder text", "default": "#5a5a5a" },

    { "type": "header", "content": "Submit button colors" },
    { "type": "color", "id": "button_bg", "label": "Background", "default": "#000000" },
    { "type": "color", "id": "button_text_color", "label": "Text", "default": "#ffffff" },
    { "type": "color", "id": "button_border", "label": "Border", "default": "#000000" }
  ],
  "presets": [
    { "name": "Insurance Form" }
  ]
}
{% endschema %}
