{% comment %}
  Section: Product Categories
  File: sections/product-categories.liquid
{% endcomment %}

{%- liquid
  assign pad_top = section.settings.padding_top | default: 100
  assign pad_bottom = section.settings.padding_bottom | default: 100
  assign pad_x = section.settings.padding_x | default: 0
  assign margin_top = section.settings.margin_top | default: 0
  assign margin_bottom = section.settings.margin_bottom | default: 0
-%}

<section class="products-section" style="padding: {{ pad_top }}px {{ pad_x }}px {{ pad_bottom }}px; margin: {{ margin_top }}px 0 {{ margin_bottom }}px;">
  <div class="container-sm">
    {%- if section.settings.show_eyebrow -%}
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow center" data-reveal>{{ section.settings.eyebrow }}</p>
      {%- endif -%}
    {%- endif -%}
    {%- if section.settings.show_heading -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="section-title center" data-reveal data-reveal-delay="80">{{ section.settings.heading }}</h2>
      {%- endif -%}
    {%- endif -%}
    {%- if section.settings.show_subheading -%}
      {%- if section.settings.subheading != blank -%}
        <p class="section-sub center" data-reveal data-reveal-delay="160">{{ section.settings.subheading }}</p>
      {%- endif -%}
    {%- endif -%}

    <div class="products-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          {%- assign card_delay = forloop.index0 | times: 100 -%}
          <a href="{{ block.settings.link | default: '#' }}" class="product-card" data-reveal data-reveal-delay="{{ card_delay }}" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1200 | image_tag: alt: block.settings.title, loading: 'lazy' }}
            {%- endif -%}
            <h3 data-reveal data-reveal-delay="{{ card_delay | plus: 200 }}">{{ block.settings.title }}</h3>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.show_primary_cta or section.settings.show_secondary_cta -%}
      <div class="products-cta">
        {%- if section.settings.show_primary_cta -%}
          {%- if section.settings.primary_cta_text != blank -%}
            <a href="{{ section.settings.primary_cta_link | default: '#' }}" class="btn btn-primary">
              {{ section.settings.primary_cta_text }}
            </a>
          {%- endif -%}
        {%- endif -%}

        {%- if section.settings.show_secondary_cta -%}
          {%- if section.settings.secondary_cta_text != blank -%}
            <a href="{{ section.settings.secondary_cta_link | default: '#' }}" class="link-arrow">
              {{ section.settings.secondary_cta_text }}
              {% render 'icon-arrow-right', size: 15, height: 16, color: 'black' %}
            </a>
          {%- endif -%}
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product Categories",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Products" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Everything you need for pregnancy and beyond" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },

    { "type": "header", "content": "Show / hide elements" },
    { "type": "checkbox", "id": "show_eyebrow", "label": "Show eyebrow", "default": true },
    { "type": "checkbox", "id": "show_heading", "label": "Show heading", "default": true },
    { "type": "checkbox", "id": "show_subheading", "label": "Show subheading", "default": true },
    { "type": "checkbox", "id": "show_primary_cta", "label": "Show primary button", "default": true },
    { "type": "checkbox", "id": "show_secondary_cta", "label": "Show secondary link", "default": true },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_x", "label": "Padding left / right", "min": 0, "max": 96, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_top", "label": "Margin top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_bottom", "label": "Margin bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },

    { "type": "header", "content": "Primary CTA" },
    { "type": "text", "id": "primary_cta_text", "label": "Button text", "default": "Check Coverage" },
    { "type": "url", "id": "primary_cta_link", "label": "Button link" },

    { "type": "header", "content": "Secondary CTA" },
    { "type": "text", "id": "secondary_cta_text", "label": "Link text", "default": "Shop Products" },
    { "type": "url", "id": "secondary_cta_link", "label": "Link URL" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Categories",
      "blocks": [
        { "type": "category", "settings": { "title": "Breast Pumps" } },
        { "type": "category", "settings": { "title": "Belly Bands" } },
        { "type": "category", "settings": { "title": "Postpartum Garments" } },
        { "type": "category", "settings": { "title": "Maternity Bundles" } }
      ]
    }
  ]
}
{% endschema %}
