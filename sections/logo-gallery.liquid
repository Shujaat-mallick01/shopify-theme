{% comment %}
  Section: Logo Gallery (configurable grid of logos)
  File: sections/logo-gallery.liquid
{% endcomment %}

{%- liquid
  assign pad_top = section.settings.padding_top | default: 80
  assign pad_bottom = section.settings.padding_bottom | default: 80
  assign pad_x = section.settings.padding_x | default: 64
  assign margin_top = section.settings.margin_top | default: 0
  assign margin_bottom = section.settings.margin_bottom | default: 0
  assign logo_height = section.settings.logo_height | default: 56
  assign cols = section.settings.columns | default: 3
  assign col_gap = section.settings.column_gap | default: 80
  assign row_gap = section.settings.row_gap | default: 80
-%}

<section class="lg-section" style="
  --lg-bg: {{ section.settings.background_color | default: '#ffffff' }};
  --lg-eyebrow-color: {{ section.settings.eyebrow_color | default: '#000000' }};
  --lg-heading-color: {{ section.settings.heading_color | default: '#000000' }};
  --lg-sub-color: {{ section.settings.sub_color | default: '#000000' }};
  --lg-logo-height: {{ logo_height }}px;
  --lg-cols: {{ cols }};
  --lg-col-gap: {{ col_gap }}px;
  --lg-row-gap: {{ row_gap }}px;
  background: var(--lg-bg, #fff);
  padding: {{ pad_top }}px {{ pad_x }}px {{ pad_bottom }}px;
  margin: {{ margin_top }}px 0 {{ margin_bottom }}px;
">
  <div class="lg-container">

    {%- if section.settings.show_title -%}
      {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank -%}
        <div class="lg-title">
          {%- if section.settings.show_eyebrow -%}
            {%- if section.settings.eyebrow != blank -%}
              <p class="lg-eyebrow" data-reveal>{{ section.settings.eyebrow }}</p>
            {%- endif -%}
          {%- endif -%}
          {%- if section.settings.show_heading -%}
            {%- if section.settings.heading != blank -%}
              <h2 class="lg-heading" data-reveal data-reveal-delay="80">{{ section.settings.heading }}</h2>
            {%- endif -%}
          {%- endif -%}
          {%- if section.settings.show_subheading -%}
            {%- if section.settings.subheading != blank -%}
              <p class="lg-sub" data-reveal data-reveal-delay="160">{{ section.settings.subheading }}</p>
            {%- endif -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endif -%}

    <div class="lg-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'logo' -%}
          {%- assign l_delay = forloop.index0 | times: 80 -%}
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="lg-item" data-reveal data-reveal-delay="{{ l_delay }}" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 400 | image_tag: alt: block.settings.alt, loading: 'lazy' }}
              {%- else -%}
                <div class="lg-item-placeholder" aria-hidden="true"></div>
              {%- endif -%}
            </a>
          {%- else -%}
            <div class="lg-item" data-reveal data-reveal-delay="{{ l_delay }}" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 400 | image_tag: alt: block.settings.alt, loading: 'lazy' }}
              {%- else -%}
                <div class="lg-item-placeholder" aria-hidden="true"></div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Logo Gallery",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Optional title (above grid)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "richtext", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },

    { "type": "header", "content": "Grid" },
    { "type": "range", "id": "columns", "label": "Columns per row", "min": 2, "max": 6, "step": 1, "default": 3 },
    { "type": "range", "id": "column_gap", "label": "Column gap", "min": 16, "max": 160, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "row_gap", "label": "Row gap", "min": 16, "max": 160, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "logo_height", "label": "Logo height", "min": 24, "max": 120, "step": 4, "unit": "px", "default": 56 },

    { "type": "header", "content": "Show / hide elements" },
    { "type": "checkbox", "id": "show_title", "label": "Show title block", "default": false },
    { "type": "checkbox", "id": "show_eyebrow", "label": "Show eyebrow", "default": true },
    { "type": "checkbox", "id": "show_heading", "label": "Show heading", "default": true },
    { "type": "checkbox", "id": "show_subheading", "label": "Show subheading", "default": true },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_x", "label": "Padding left / right", "min": 0, "max": 96, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "margin_top", "label": "Margin top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_bottom", "label": "Margin bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow", "default": "#000000" },
    { "type": "color", "id": "heading_color", "label": "Heading", "default": "#000000" },
    { "type": "color", "id": "sub_color", "label": "Subheading", "default": "#000000" }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Logo image" },
        { "type": "text", "id": "alt", "label": "Alt text" },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "max_blocks": 24,
  "presets": [
    {
      "name": "Logo Gallery",
      "blocks": [
        { "type": "logo" }, { "type": "logo" }, { "type": "logo" },
        { "type": "logo" }, { "type": "logo" }, { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
