{% comment %}
  Section: Main Page
  File: sections/main-page.liquid
  Renders a Shopify page's title + rich-text content.
{% endcomment %}

<section class="page-main">
  <div class="container">
    {%- if section.settings.show_title -%}
      <h1 class="page-title">{{ page.title }}</h1>
    {%- endif -%}
    <div class="page-content rte">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page",
  "tag": "section",
  "settings": [
    { "type": "checkbox", "id": "show_title", "label": "Show page title", "default": true }
  ]
}
{% endschema %}
