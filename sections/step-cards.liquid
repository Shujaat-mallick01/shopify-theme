{% comment %}
  Section: Step Cards (4-step horizontal cards with background image + icon)
  File: sections/step-cards.liquid
  Figma: "Layout / 521"
{% endcomment %}

{%- liquid
  assign pad_top = section.settings.padding_top | default: 112
  assign pad_bottom = section.settings.padding_bottom | default: 112
  assign pad_x = section.settings.padding_x | default: 64
  assign margin_top = section.settings.margin_top | default: 0
  assign margin_bottom = section.settings.margin_bottom | default: 0
-%}

<section class="step-cards" style="
  --sc-bg: {{ section.settings.background_color | default: '#ffffff' }};
  --sc-eyebrow-color: {{ section.settings.eyebrow_color | default: '#000000' }};
  --sc-heading-color: {{ section.settings.heading_color | default: '#000000' }};
  --sc-sub-color: {{ section.settings.sub_color | default: '#000000' }};
  --sc-card-fallback: {{ section.settings.card_fallback_color | default: '#8a8a8a' }};
  --sc-card-overlay: {{ section.settings.card_overlay_color | default: '#000000' }};
  --sc-card-overlay-alpha: {{ section.settings.card_overlay_opacity | default: 40 | times: 0.01 }};
  --sc-card-icon: {{ section.settings.card_icon_color | default: '#ffffff' }};
  --sc-card-heading: {{ section.settings.card_heading_color | default: '#ffffff' }};
  --sc-card-desc: {{ section.settings.card_desc_color | default: '#ffffff' }};
  --sc-card-link: {{ section.settings.card_link_color | default: '#ffffff' }};
  background: var(--sc-bg, #fff);
  padding: {{ pad_top }}px {{ pad_x }}px {{ pad_bottom }}px;
  margin: {{ margin_top }}px 0 {{ margin_bottom }}px;
">
  <div class="step-cards-container">

    <div class="step-cards-title">
      {%- if section.settings.show_eyebrow -%}
        {%- if section.settings.eyebrow != blank -%}
          <p class="step-cards-eyebrow" data-reveal>{{ section.settings.eyebrow }}</p>
        {%- endif -%}
      {%- endif -%}
      {%- if section.settings.show_heading -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="step-cards-heading" data-reveal data-reveal-delay="80">{{ section.settings.heading }}</h2>
        {%- endif -%}
      {%- endif -%}
      {%- if section.settings.show_description -%}
        {%- if section.settings.description != blank -%}
          <p class="step-cards-sub" data-reveal data-reveal-delay="160">{{ section.settings.description }}</p>
        {%- endif -%}
      {%- endif -%}
    </div>

    <div class="step-cards-row">
      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          {%- assign card_delay = forloop.index0 | times: 120 -%}
          <article class="step-card-item u-hover-lift" data-reveal data-reveal-delay="{{ card_delay }}" {{ block.shopify_attributes }}>
            {%- if block.settings.background_image != blank -%}
              {{ block.settings.background_image | image_url: width: 800 | image_tag: alt: block.settings.heading, loading: 'lazy', class: 'step-card-bg-img' }}
            {%- endif -%}
            <div class="step-card-overlay" aria-hidden="true"></div>

            <div class="step-card-inner">
              <div class="step-card-top">
                <div class="step-card-icon" aria-hidden="true">
                  {%- if block.settings.icon != blank -%}
                    {{ block.settings.icon | image_url: width: 96 | image_tag: alt: '', loading: 'lazy' }}
                  {%- else -%}
                    <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M24 6 L42 14.5 V33.5 L24 42 L6 33.5 V14.5 Z" stroke="currentColor" stroke-width="2.4" stroke-linejoin="round" fill="none"/>
                      <path d="M6 14.5 L24 23 L42 14.5" stroke="currentColor" stroke-width="2.4" stroke-linejoin="round" fill="none"/>
                      <path d="M24 23 V42" stroke="currentColor" stroke-width="2.4" stroke-linejoin="round"/>
                    </svg>
                  {%- endif -%}
                </div>
                <div class="step-card-content">
                  {%- if block.settings.heading != blank -%}
                    <h3 class="step-card-heading" data-reveal data-reveal-delay="{{ card_delay | plus: 200 }}">{{ block.settings.heading }}</h3>
                  {%- endif -%}
                  {%- if block.settings.description != blank -%}
                    <p class="step-card-desc" data-reveal data-reveal-delay="{{ card_delay | plus: 300 }}">{{ block.settings.description }}</p>
                  {%- endif -%}
                </div>
              </div>

              {%- if block.settings.link_text != blank -%}
                <div class="step-card-actions">
                  <a href="{{ block.settings.link | default: '#' }}" class="step-card-link">
                    <span>{{ block.settings.link_text }}</span>
                    <svg width="7" height="12" viewBox="0 0 7 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M0.877 0.5C0.978 0.5 1.055 0.53 1.133 0.608L6.077 5.553C6.131 5.607 6.156 5.649 6.168 5.677V5.678C6.183 5.713 6.191 5.753 6.191 5.802C6.191 5.85 6.183 5.89 6.168 5.926V5.927C6.156 5.955 6.131 5.997 6.077 6.051L1.108 11.02C1.031 11.097 0.963 11.119 0.883 11.116C0.789 11.113 0.708 11.081 0.622 10.995C0.544 10.917 0.513 10.84 0.513 10.739C0.513 10.638 0.544 10.561 0.622 10.483L5.304 5.802L0.597 1.095C0.519 1.017 0.497 0.951 0.5 0.87C0.503 0.776 0.536 0.694 0.622 0.608C0.7 0.531 0.776 0.5 0.877 0.5Z" fill="#fff" stroke="#fff"/>
                    </svg>
                  </a>
                </div>
              {%- endif -%}
            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Step Cards",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Simple" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Four steps to coverage" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "We handle the paperwork so you don't have to." },

    { "type": "header", "content": "Show / hide elements" },
    { "type": "checkbox", "id": "show_eyebrow", "label": "Show eyebrow", "default": true },
    { "type": "checkbox", "id": "show_heading", "label": "Show heading", "default": true },
    { "type": "checkbox", "id": "show_description", "label": "Show description", "default": true },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 112 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 112 },
    { "type": "range", "id": "padding_x", "label": "Padding left / right", "min": 0, "max": 96, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "margin_top", "label": "Margin top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_bottom", "label": "Margin bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },

    { "type": "header", "content": "Section colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow", "default": "#000000" },
    { "type": "color", "id": "heading_color", "label": "Heading", "default": "#000000" },
    { "type": "color", "id": "sub_color", "label": "Subheading", "default": "#000000" },

    { "type": "header", "content": "Step card colors" },
    { "type": "color", "id": "card_fallback_color", "label": "Card fallback (no image)", "default": "#8a8a8a" },
    { "type": "color", "id": "card_overlay_color", "label": "Image overlay color", "default": "#000000" },
    { "type": "range", "id": "card_overlay_opacity", "label": "Image overlay opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 40 },
    { "type": "color", "id": "card_icon_color", "label": "Icon", "default": "#ffffff" },
    { "type": "color", "id": "card_heading_color", "label": "Heading", "default": "#ffffff" },
    { "type": "color", "id": "card_desc_color", "label": "Description", "default": "#ffffff" },
    { "type": "color", "id": "card_link_color", "label": "Link", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step card",
      "settings": [
        { "type": "image_picker", "id": "background_image", "label": "Background image" },
        { "type": "image_picker", "id": "icon", "label": "Icon (optional, defaults to box)" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Step heading" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "text", "id": "link_text", "label": "Link text", "default": "Next" },
        { "type": "url", "id": "link", "label": "Link URL" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Step Cards",
      "blocks": [
        { "type": "step", "settings": { "heading": "Submit your insurance information", "description": "Tell us about your plan and coverage details.", "link_text": "Next" } },
        { "type": "step", "settings": { "heading": "We verify your coverage", "description": "Our team checks what your insurance will cover.", "link_text": "Next" } },
        { "type": "step", "settings": { "heading": "Choose your products", "description": "Browse breast pumps, storage bags, and essentials.", "link_text": "Next" } },
        { "type": "step", "settings": { "heading": "We deliver direct to your door", "description": "Your maternity products arrive when you need them.", "link_text": "Done" } }
      ]
    }
  ]
}
{% endschema %}
