{% comment %}
  Section: Main Blog
  File: sections/main-blog.liquid
{% endcomment %}

<section class="blog-main">
  <div class="container">
    <h1 class="blog-title">{{ blog.title }}</h1>

    {%- paginate blog.articles by section.settings.posts_per_page -%}
      <ul class="article-list">
        {%- for article in blog.articles -%}
          <li class="article-card">
            {%- if article.image != blank -%}
              <a href="{{ article.url }}" class="article-card-image">
                {{ article.image | image_url: width: 1000 | image_tag: alt: article.title, loading: 'lazy' }}
              </a>
            {%- endif -%}
            <h2><a href="{{ article.url }}">{{ article.title }}</a></h2>
            <p class="article-meta">
              {{ article.published_at | date: '%b %d, %Y' }}
              {%- if article.author != blank %} · {{ article.author }}{% endif -%}
            </p>
            <p>{{ article.excerpt_or_content | strip_html | truncate: 200 }}</p>
            <a href="{{ article.url }}" class="link-arrow">Read more</a>
          </li>
        {%- else -%}
          <li>No articles yet.</li>
        {%- endfor -%}
      </ul>

      {%- if paginate.pages > 1 -%}
        <div class="pagination">{{ paginate | default_pagination }}</div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog",
  "tag": "section",
  "settings": [
    { "type": "range", "id": "posts_per_page", "label": "Posts per page", "min": 4, "max": 24, "step": 2, "default": 12 }
  ]
}
{% endschema %}
