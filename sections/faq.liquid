{% comment %}
  Section: FAQ
  File: sections/faq.liquid
  Figma: "FAQ / 4"
  Uses native <details>/<summary> — no JS needed for the accordion.
{% endcomment %}

{%- liquid
  assign pad_top = section.settings.padding_top | default: 112
  assign pad_bottom = section.settings.padding_bottom | default: 112
  assign pad_x = section.settings.padding_x | default: 64
  assign margin_top = section.settings.margin_top | default: 0
  assign margin_bottom = section.settings.margin_bottom | default: 0
-%}

<section class="faq-section" style="
  --faq-bg: {{ section.settings.background_color | default: '#ffffff' }};
  --faq-heading-color: {{ section.settings.heading_color | default: '#000000' }};
  --faq-sub-color: {{ section.settings.sub_color | default: '#000000' }};
  --faq-item-bg: {{ section.settings.item_bg | default: '#ffffff' }};
  --faq-item-bg-hover: {{ section.settings.item_bg_hover | default: '#fafafa' }};
  --faq-item-border: {{ section.settings.item_border | default: '#000000' }};
  --faq-question-color: {{ section.settings.question_color | default: '#000000' }};
  --faq-answer-color: {{ section.settings.answer_color | default: '#000000' }};
  --faq-icon-color: {{ section.settings.icon_color | default: '#000000' }};
  background: var(--faq-bg, #fff);
  padding: {{ pad_top }}px {{ pad_x }}px {{ pad_bottom }}px;
  margin: {{ margin_top }}px 0 {{ margin_bottom }}px;
">
  <div class="faq-container">

    <div class="faq-title">
      {%- if section.settings.show_heading -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="faq-heading" data-reveal>{{ section.settings.heading }}</h2>
        {%- endif -%}
      {%- endif -%}
      {%- if section.settings.show_subheading -%}
        {%- if section.settings.subheading != blank -%}
          <p class="faq-sub" data-reveal data-reveal-delay="100">{{ section.settings.subheading }}</p>
        {%- endif -%}
      {%- endif -%}
    </div>

    <div class="faq-list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'question' -%}
          {%- assign d = forloop.index0 | times: 80 -%}
          <details class="faq-item" data-reveal data-reveal-delay="{{ d }}" {% if block.settings.open_by_default %}open{% endif %} {{ block.shopify_attributes }}>
            <summary class="faq-question">
              <span class="faq-question-text">{{ block.settings.question }}</span>
              <span class="faq-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  <line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </span>
            </summary>
            <div class="faq-answer">{{ block.settings.answer }}</div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Questions" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Find answers about your coverage and what happens next." },

    { "type": "header", "content": "Show / hide elements" },
    { "type": "checkbox", "id": "show_heading", "label": "Show heading", "default": true },
    { "type": "checkbox", "id": "show_subheading", "label": "Show subheading", "default": true },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 112 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 112 },
    { "type": "range", "id": "padding_x", "label": "Padding left / right", "min": 0, "max": 96, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "margin_top", "label": "Margin top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_bottom", "label": "Margin bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },

    { "type": "header", "content": "Section colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading", "default": "#000000" },
    { "type": "color", "id": "sub_color", "label": "Subheading", "default": "#000000" },

    { "type": "header", "content": "Accordion item colors" },
    { "type": "color", "id": "item_bg", "label": "Item background", "default": "#ffffff" },
    { "type": "color", "id": "item_bg_hover", "label": "Item background (hover)", "default": "#fafafa" },
    { "type": "color", "id": "item_border", "label": "Item border", "default": "#000000" },
    { "type": "color", "id": "question_color", "label": "Question text", "default": "#000000" },
    { "type": "color", "id": "answer_color", "label": "Answer text", "default": "#000000" },
    { "type": "color", "id": "icon_color", "label": "Plus/close icon", "default": "#000000" }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Question goes here" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Answer goes here.</p>" },
        { "type": "checkbox", "id": "open_by_default", "label": "Open by default", "default": false }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "question", "settings": { "question": "What does insurance cover?", "answer": "<p>Most plans cover breast pumps, storage bags, and postpartum essentials. We verify your specific benefits once you submit your information.</p>" } },
        { "type": "question", "settings": { "question": "How long does verification take?", "answer": "<p>We typically verify coverage within 24 hours. You'll receive an email with your results and next steps.</p>" } },
        { "type": "question", "settings": { "question": "Is my information private?", "answer": "<p>Yes. We protect your data and use it only to verify your insurance coverage. Your privacy matters to us.</p>" } },
        { "type": "question", "settings": { "question": "What if I'm not covered?", "answer": "<p>We'll let you know what your plan includes and help you explore options.</p>" } },
        { "type": "question", "settings": { "question": "Can I shop before verification?", "answer": "<p>You can browse and buy our products anytime without insurance coverage.</p>" } }
      ]
    }
  ]
}
{% endschema %}
