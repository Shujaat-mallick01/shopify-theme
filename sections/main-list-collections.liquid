{% comment %}
  Section: Main List Collections
  File: sections/main-list-collections.liquid
{% endcomment %}

<section class="list-collections-main">
  <div class="container">
    <h1>{{ section.settings.heading | default: 'Collections' }}</h1>

    <div class="collections-grid">
      {%- for collection in collections -%}
        <a href="{{ collection.url }}" class="collection-card-block">
          {%- if collection.featured_image != blank -%}
            {{ collection.featured_image | image_url: width: 800 | image_tag: alt: collection.title, loading: 'lazy' }}
          {%- endif -%}
          <h2>{{ collection.title }}</h2>
        </a>
      {%- else -%}
        <p>No collections yet.</p>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collections list",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Collections" }
  ]
}
{% endschema %}
