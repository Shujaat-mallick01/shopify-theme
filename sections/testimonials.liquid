{% comment %}
  Section: Testimonials
  File: sections/testimonials.liquid
{% endcomment %}

{%- liquid
  assign pad_top = section.settings.padding_top | default: 100
  assign pad_bottom = section.settings.padding_bottom | default: 100
  assign pad_x = section.settings.padding_x | default: 0
  assign margin_top = section.settings.margin_top | default: 0
  assign margin_bottom = section.settings.margin_bottom | default: 0
-%}

<section class="testimonials-section" style="
  --testimonials-bg: {{ section.settings.background_color | default: '#fce4e6' }};
  --t-heading-color: {{ section.settings.heading_color | default: '#000000' }};
  --t-sub-color: {{ section.settings.sub_color | default: '#000000' }};
  --t-card-bg: {{ section.settings.card_bg | default: '#ffffff' }};
  --t-card-border: {{ section.settings.card_border | default: '#000000' }};
  --t-quote-color: {{ section.settings.quote_color | default: '#000000' }};
  --t-author-name-color: {{ section.settings.author_name_color | default: '#000000' }};
  --t-author-role-color: {{ section.settings.author_role_color | default: '#000000' }};
  --t-logo-color: {{ section.settings.logo_color | default: '#5a5a5a' }};
  --t-link-color: {{ section.settings.link_color | default: '#000000' }};
  padding: {{ pad_top }}px {{ pad_x }}px {{ pad_bottom }}px;
  margin: {{ margin_top }}px 0 {{ margin_bottom }}px;
">
  <div class="container-sm">
    {%- if section.settings.show_heading -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="section-title" data-reveal>{{ section.settings.heading }}</h2>
      {%- endif -%}
    {%- endif -%}
    {%- if section.settings.show_subheading -%}
      {%- if section.settings.subheading != blank -%}
        <p class="section-sub" data-reveal data-reveal-delay="80">{{ section.settings.subheading }}</p>
      {%- endif -%}
    {%- endif -%}

    <div class="testimonials-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'testimonial' -%}
          {%- assign t_delay = forloop.index0 | times: 120 -%}
          <article class="testimonial u-hover-lift" data-reveal data-reveal-delay="{{ t_delay }}" {{ block.shopify_attributes }}>
            {%- if block.settings.logo != blank -%}
              <div class="testimonial-logo" data-reveal data-reveal-delay="{{ t_delay | plus: 150 }}">
                {{ block.settings.logo | image_url: width: 200 | image_tag: alt: '', loading: 'lazy' }}
              </div>
            {%- endif -%}

            {%- if block.settings.quote != blank -%}
              <p data-reveal data-reveal-delay="{{ t_delay | plus: 200 }}">"{{ block.settings.quote }}"</p>
            {%- endif -%}

            <div class="testimonial-author" data-reveal data-reveal-delay="{{ t_delay | plus: 300 }}">
              <div class="avatar">
                {%- if block.settings.avatar != blank -%}
                  {{ block.settings.avatar | image_url: width: 80 | image_tag: alt: block.settings.author_name, loading: 'lazy' }}
                {%- endif -%}
              </div>
              <div>
                <strong>{{ block.settings.author_name }}</strong>
                <span>{{ block.settings.author_role }}</span>
              </div>
            </div>

            {%- if block.settings.link_text != blank -%}
              <a href="{{ block.settings.link | default: '#' }}" class="link-arrow small">
                {{ block.settings.link_text }}
                {% render 'icon-arrow-right', size: 15, height: 16, color: 'black' %}
              </a>
            {%- endif -%}
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "settings": [
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#fce4e6" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Trusted by healthcare providers <em>and</em> moms</p>" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "What they're saying" },

    { "type": "header", "content": "Show / hide elements" },
    { "type": "checkbox", "id": "show_heading", "label": "Show heading", "default": true },
    { "type": "checkbox", "id": "show_subheading", "label": "Show subheading", "default": true },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_x", "label": "Padding left / right", "min": 0, "max": 96, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_top", "label": "Margin top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_bottom", "label": "Margin bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },

    { "type": "header", "content": "Text colors" },
    { "type": "color", "id": "heading_color", "label": "Heading", "default": "#000000" },
    { "type": "color", "id": "sub_color", "label": "Subheading", "default": "#000000" },

    { "type": "header", "content": "Card colors" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#ffffff" },
    { "type": "color", "id": "card_border", "label": "Card border", "default": "#000000" },
    { "type": "color", "id": "logo_color", "label": "Logo text", "default": "#5a5a5a" },
    { "type": "color", "id": "quote_color", "label": "Quote text", "default": "#000000" },
    { "type": "color", "id": "author_name_color", "label": "Author name", "default": "#000000" },
    { "type": "color", "id": "author_role_color", "label": "Author role", "default": "#000000" },
    { "type": "color", "id": "link_color", "label": "Link", "default": "#000000" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo image" },
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "image_picker", "id": "avatar", "label": "Avatar image" },
        { "type": "text", "id": "author_name", "label": "Author name" },
        { "type": "text", "id": "author_role", "label": "Author role / title" },
        { "type": "text", "id": "link_text", "label": "Link text", "default": "Read her story" },
        { "type": "url", "id": "link", "label": "Link URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial", "settings": { "author_name": "Sarah Mitchell", "author_role": "Mother of two", "quote": "This pump made going back to work possible." } },
        { "type": "testimonial", "settings": { "author_name": "Jessica Chen", "author_role": "New mother" } },
        { "type": "testimonial", "settings": { "author_name": "Maria Rodriguez", "author_role": "Breastfeeding mother" } }
      ]
    }
  ]
}
{% endschema %}
