{% comment %}
  Section: Steps (3 Simple Steps)
  File: sections/steps.liquid
{% endcomment %}

{%- liquid
  assign pad_top = section.settings.padding_top | default: 100
  assign pad_bottom = section.settings.padding_bottom | default: 100
  assign pad_x = section.settings.padding_x | default: 0
  assign margin_top = section.settings.margin_top | default: 0
  assign margin_bottom = section.settings.margin_bottom | default: 0
-%}

<section class="steps-section" style="
  --steps-bg: {{ section.settings.background_color | default: '#ffffff' }};
  --steps-eyebrow-color: {{ section.settings.eyebrow_color | default: '#000000' }};
  --steps-heading-color: {{ section.settings.heading_color | default: '#000000' }};
  --steps-sub-color: {{ section.settings.sub_color | default: '#000000' }};
  --steps-card-overlay: {{ section.settings.card_overlay_color | default: '#000000' }};
  --steps-card-overlay-alpha: {{ section.settings.card_overlay_opacity | default: 40 | times: 0.01 }};
  --steps-card-number: {{ section.settings.card_number_color | default: '#ffffff' }};
  --steps-card-heading: {{ section.settings.card_heading_color | default: '#ffffff' }};
  --steps-card-text: {{ section.settings.card_text_color | default: '#ffffff' }};
  --steps-card-link: {{ section.settings.card_link_color | default: '#ffffff' }};
  background: var(--steps-bg, #fff);
  padding: {{ pad_top }}px {{ pad_x }}px {{ pad_bottom }}px;
  margin: {{ margin_top }}px 0 {{ margin_bottom }}px;
">
  <div class="container">
    {%- if section.settings.show_eyebrow -%}
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow" data-reveal>{{ section.settings.eyebrow }}</p>
      {%- endif -%}
    {%- endif -%}

    {%- if section.settings.show_heading -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="section-title" data-reveal data-reveal-delay="80">{{ section.settings.heading }}</h2>
      {%- endif -%}
    {%- endif -%}

    {%- if section.settings.show_subheading -%}
      {%- if section.settings.subheading != blank -%}
        <p class="section-sub" data-reveal data-reveal-delay="160">{{ section.settings.subheading }}</p>
      {%- endif -%}
    {%- endif -%}

    <div class="steps-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          {%- assign step_delay = forloop.index0 | times: 120 -%}
          <article class="step-card u-hover-lift" data-reveal data-reveal-delay="{{ step_delay }}" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1000 | image_tag: alt: block.settings.heading, loading: 'lazy' }}
            {%- endif -%}
            <div class="step-content">
              {%- if block.settings.step_number != blank -%}
                <span class="step-number" data-reveal data-reveal-delay="200">{{ block.settings.step_number }}</span>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <h3 data-reveal data-reveal-delay="280">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p data-reveal data-reveal-delay="360">{{ block.settings.description }}</p>
              {%- endif -%}
              {%- if block.settings.link_text != blank -%}
                <a href="{{ block.settings.link | default: '#' }}" class="link-arrow" data-reveal data-reveal-delay="440">
                  {{ block.settings.link_text }}
                  {% render 'icon-arrow-right', color: 'white' %}
                </a>
              {%- endif -%}
            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Steps",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "3 SIMPLE STEPS TO" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Get the Maternity Products You Need Through Every Stage of Motherhood Covered Through Insurance" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "From breast pumps, to milk bags and belly bands, we've got you covered." },

    { "type": "header", "content": "Show / hide elements" },
    { "type": "checkbox", "id": "show_eyebrow", "label": "Show eyebrow", "default": true },
    { "type": "checkbox", "id": "show_heading", "label": "Show heading", "default": true },
    { "type": "checkbox", "id": "show_subheading", "label": "Show subheading", "default": true },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_x", "label": "Padding left / right", "min": 0, "max": 96, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_top", "label": "Margin top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_bottom", "label": "Margin bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },

    { "type": "header", "content": "Section colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow", "default": "#000000" },
    { "type": "color", "id": "heading_color", "label": "Heading", "default": "#000000" },
    { "type": "color", "id": "sub_color", "label": "Subheading", "default": "#000000" },

    { "type": "header", "content": "Step card colors" },
    { "type": "color", "id": "card_overlay_color", "label": "Image overlay color", "default": "#000000" },
    { "type": "range", "id": "card_overlay_opacity", "label": "Image overlay opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 40 },
    { "type": "color", "id": "card_number_color", "label": "Step number", "default": "#ffffff" },
    { "type": "color", "id": "card_heading_color", "label": "Heading", "default": "#ffffff" },
    { "type": "color", "id": "card_text_color", "label": "Description", "default": "#ffffff" },
    { "type": "color", "id": "card_link_color", "label": "Link", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "step_number", "label": "Step number", "default": "Step 1" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Check your coverage" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "text", "id": "link_text", "label": "Link text", "default": "Learn More" },
        { "type": "url", "id": "link", "label": "Link URL" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Steps",
      "blocks": [
        { "type": "step", "settings": { "step_number": "Step 1", "heading": "Check your coverage", "description": "Check your insurance, and let's verify what's covered.", "link_text": "Check Coverage" } },
        { "type": "step", "settings": { "step_number": "Step 2", "heading": "Shop our products", "description": "Browse breast pumps, belly bands, and maternity essentials you need.", "link_text": "Shop Now" } },
        { "type": "step", "settings": { "step_number": "Step 3", "heading": "Focus on your baby", "description": "We handle everything: from insurance, to your door, and beyond.", "link_text": "Learn More" } }
      ]
    }
  ]
}
{% endschema %}
