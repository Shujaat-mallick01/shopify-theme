{% comment %}
  Section: Header
  File: sections/header.liquid
  Logo + nav with per-link mega-menu panels and shared "Contact our team" footer.
{% endcomment %}

<header class="site-header">
  <div class="header">
    <div class="header-container">
      <div class="header-content">

        {%- comment -%} Logo {%- endcomment -%}
        <a href="{{ routes.root_url }}" class="logo-wrap" aria-label="{{ shop.name }}">
          <div class="logo-wide">
            {%- if section.settings.logo != blank -%}
              {{ section.settings.logo | image_url: width: 400 | image_tag: alt: shop.name, loading: 'eager', class: 'logo-img' }}
              {% comment %} {{ section.settings.logo | image_url: width: 140 | image_tag: alt: shop.name, loading: 'eager', class: 'logo-img' }} {% endcomment %}
            {%- else -%}
              <span class="logo-text">{{ section.settings.logo_text | default: 'Logo' }}</span>
            {%- endif -%}
          </div>
        </a>

        {%- comment -%} Nav links — each can carry its own 4-item mega panel {%- endcomment -%}
        <nav class="nav-column" aria-label="Main">
          {%- for block in section.blocks -%}
            {%- if block.type == 'nav_link' -%}
              {%- assign has_mega = false -%}
              {%- if block.settings.item_1_title != blank or block.settings.item_2_title != blank or block.settings.item_3_title != blank or block.settings.item_4_title != blank -%}
                {%- assign has_mega = true -%}
              {%- endif -%}

              <div class="nav-item{% if has_mega %} nav-item-mega{% endif %}" {{ block.shopify_attributes }}>
                <a href="{{ block.settings.link | default: '#' }}" class="nav-link">
                  <span class="nav-link-text">{{ block.settings.label }}</span>
                  {%- if block.settings.show_chevron -%}
                    {% render 'icon-chevron-down' %}
                  {%- endif -%}
                </a>

                {%- if has_mega -%}
                  <div class="mega-panel" role="menu" aria-label="{{ block.settings.label }}">
                    <div class="mega-panel-inner">
                      {%- for i in (1..4) -%}
                        {%- assign t_key = 'item_' | append: i | append: '_title' -%}
                        {%- assign d_key = 'item_' | append: i | append: '_desc' -%}
                        {%- assign l_key = 'item_' | append: i | append: '_link' -%}
                        {%- assign mega_title = block.settings[t_key] -%}
                        {%- assign mega_desc  = block.settings[d_key] -%}
                        {%- assign mega_link  = block.settings[l_key] -%}
                        {%- if mega_title != blank -%}
                          <a href="{{ mega_link | default: '#' }}" class="mega-item">
                            <span class="mega-item-icon" aria-hidden="true">
                              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M20.3 6.3a1 1 0 0 1 0 1.4l-10 10a1 1 0 0 1-1.4 0l-5-5a1 1 0 1 1 1.4-1.4L9.6 15.6l9.3-9.3a1 1 0 0 1 1.4 0z" fill="#000" stroke="#000" stroke-width="0.5"/>
                              </svg>
                            </span>
                            <span class="mega-item-content">
                              <span class="mega-item-title">{{ mega_title }}</span>
                              {%- if mega_desc != blank -%}
                                <span class="mega-item-desc">{{ mega_desc }}</span>
                              {%- endif -%}
                            </span>
                          </a>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>

                    {%- if section.settings.mega_footer_text != blank -%}
                      <div class="mega-panel-footer">
                        <span>{{ section.settings.mega_footer_text }}</span>
                        {%- if section.settings.mega_footer_link_text != blank -%}
                          <a href="{{ section.settings.mega_footer_link | default: '#' }}">{{ section.settings.mega_footer_link_text }}</a>
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </nav>
      </div>

      {%- comment -%} Actions {%- endcomment -%}
      <div class="header-actions">
        {%- if section.settings.show_phone -%}
          <div class="btn-action">
            <div class="talk-to-team">
              <span>{{ section.settings.phone_label }}</span>
              <span>{{ section.settings.phone_hours }}</span>
              <span>{{ section.settings.phone_number }}</span>
            </div>
          </div>
        {%- endif -%}

        <a href="{{ section.settings.cta_link | default: '#' }}" class="btn-action primary">
          <span>{{ section.settings.cta_text | default: 'Shop Now' }}</span>
        </a>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "tag": "div",
  "class": "section-header-wrapper",
  "settings": [
    { "type": "header", "content": "Logo" },
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "text", "id": "logo_text", "label": "Logo text (fallback)", "default": "Logo" },

    { "type": "header", "content": "Phone / Contact" },
    { "type": "checkbox", "id": "show_phone", "label": "Show phone block", "default": true },
    { "type": "text", "id": "phone_label", "label": "Phone label", "default": "Talk To Our Team" },
    { "type": "text", "id": "phone_hours", "label": "Phone hours", "default": "9:30-5:30" },
    { "type": "text", "id": "phone_number", "label": "Phone number", "default": "xxx-xxx-xxxx" },

    { "type": "header", "content": "CTA Button" },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Shop Now" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },

    { "type": "header", "content": "Mega Menu Footer" },
    { "type": "text", "id": "mega_footer_text", "label": "Footer text", "default": "Questions about your coverage?" },
    { "type": "text", "id": "mega_footer_link_text", "label": "Footer link text", "default": "Contact our team" },
    { "type": "url", "id": "mega_footer_link", "label": "Footer link URL" }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Nav Link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Menu Item" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "checkbox", "id": "show_chevron", "label": "Show chevron", "default": true },

        { "type": "header", "content": "Mega Menu — Item 1" },
        { "type": "text", "id": "item_1_title", "label": "Title" },
        { "type": "text", "id": "item_1_desc",  "label": "Description" },
        { "type": "url",  "id": "item_1_link",  "label": "Link" },

        { "type": "header", "content": "Mega Menu — Item 2" },
        { "type": "text", "id": "item_2_title", "label": "Title" },
        { "type": "text", "id": "item_2_desc",  "label": "Description" },
        { "type": "url",  "id": "item_2_link",  "label": "Link" },

        { "type": "header", "content": "Mega Menu — Item 3" },
        { "type": "text", "id": "item_3_title", "label": "Title" },
        { "type": "text", "id": "item_3_desc",  "label": "Description" },
        { "type": "url",  "id": "item_3_link",  "label": "Link" },

        { "type": "header", "content": "Mega Menu — Item 4" },
        { "type": "text", "id": "item_4_title", "label": "Title" },
        { "type": "text", "id": "item_4_desc",  "label": "Description" },
        { "type": "url",  "id": "item_4_link",  "label": "Link" }
      ]
    }
  ],
  "default": {
    "settings": {},
    "blocks": [
      {
        "type": "nav_link",
        "settings": {
          "label": "For Moms",
          "item_1_title": "Check Insurance Coverage",
          "item_1_desc": "See if you qualify for free maternity products",
          "item_2_title": "Shop Maternity Products",
          "item_2_desc": "Browse our full range of insurance-covered essentials",
          "item_3_title": "How It Works",
          "item_3_desc": "Learn the simple 3-step process",
          "item_4_title": "Success Stories",
          "item_4_desc": "Read how we've helped thousands of moms"
        }
      },
      {
        "type": "nav_link",
        "settings": {
          "label": "For Providers",
          "item_1_title": "Submit Prescriptions",
          "item_1_desc": "Send prescriptions for your patients",
          "item_2_title": "Provider Portal",
          "item_2_desc": "Manage your patient orders",
          "item_3_title": "Resources & Education",
          "item_3_desc": "Materials for your patient consultations",
          "item_4_title": "Become a Partner",
          "item_4_desc": "Join our network of healthcare providers"
        }
      },
      {
        "type": "nav_link",
        "settings": {
          "label": "Become A Partner",
          "item_1_title": "Healthcare Provider",
          "item_1_desc": "Partner with us as a doctor or clinic",
          "item_2_title": "Insurance Network",
          "item_2_desc": "Join our insurance partnership program",
          "item_3_title": "Distributor Program",
          "item_3_desc": "Distribute Ardent products",
          "item_4_title": "Affiliate Program",
          "item_4_desc": "Earn commissions promoting Ardent"
        }
      },
      {
        "type": "nav_link",
        "settings": {
          "label": "Resources",
          "item_1_title": "Maternity Guide",
          "item_1_desc": "Comprehensive pregnancy & postpartum tips",
          "item_2_title": "Insurance Helper",
          "item_2_desc": "Understand your coverage benefits",
          "item_3_title": "Blog & News",
          "item_3_desc": "Latest updates and parenting advice",
          "item_4_title": "FAQs",
          "item_4_desc": "Find answers to common questions"
        }
