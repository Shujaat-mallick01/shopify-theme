{% comment %}
  Section: Hero Banner
  File: sections/hero-banner.liquid
{% endcomment %}

{%- liquid
  assign bg_url = ''
  if section.settings.background_image != blank
    assign bg_url = section.settings.background_image | image_url: width: 2000
  endif
  assign pad_top = section.settings.padding_top | default: 100
  assign pad_bottom = section.settings.padding_bottom | default: 100
  assign pad_x = section.settings.padding_x | default: 0
  assign margin_top = section.settings.margin_top | default: 0
  assign margin_bottom = section.settings.margin_bottom | default: 0
  assign overlay_pct = section.settings.overlay_opacity | default: 40
  assign overlay_alpha = overlay_pct | times: 0.01
-%}

<section class="hero" style="
  --hero-overlay-color: {{ section.settings.overlay_color | default: '#000000' }};
  --hero-overlay-alpha: {{ overlay_alpha }};
  --hero-heading-color: {{ section.settings.heading_color | default: '#ffffff' }};
  --hero-sub-color: {{ section.settings.sub_color | default: '#ffffff' }};
  --hero-primary-bg: {{ section.settings.primary_btn_bg | default: '#e14e6b' }};
  --hero-primary-text: {{ section.settings.primary_btn_text | default: '#ffffff' }};
  --hero-primary-border: {{ section.settings.primary_btn_border | default: '#e14e6b' }};
  --hero-secondary-bg: {{ section.settings.secondary_btn_bg | default: 'rgba(255,255,255,0.1)' }};
  --hero-secondary-text: {{ section.settings.secondary_btn_text | default: '#ffffff' }};
  --hero-secondary-border: {{ section.settings.secondary_btn_border | default: 'rgba(255,255,255,0.5)' }};
  margin: {{ margin_top }}px 0 {{ margin_bottom }}px;
">
  <div class="hero-image" style="padding: {{ pad_top }}px {{ pad_x }}px {{ pad_bottom }}px;{% if bg_url != blank %} background-image: url('{{ bg_url }}');{% endif %}">
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      {%- if section.settings.show_heading -%}
        {%- if section.settings.heading != blank -%}
          <h1 data-reveal data-reveal-delay="100">{{ section.settings.heading }}</h1>
        {%- endif -%}
      {%- endif -%}

      {%- if section.settings.show_subheading -%}
        {%- if section.settings.subheading != blank -%}
          <p class="hero-sub" data-reveal data-reveal-delay="200">{{ section.settings.subheading }}</p>
        {%- endif -%}
      {%- endif -%}

      {%- if section.settings.show_primary_cta or section.settings.show_secondary_cta -%}
        <div class="hero-buttons" data-reveal data-reveal-delay="300">
          {%- if section.settings.show_primary_cta -%}
            {%- if section.settings.primary_cta_text != blank -%}
              <a href="{{ section.settings.primary_cta_link | default: '#' }}" class="btn btn-primary">
                {{ section.settings.primary_cta_text }}
              </a>
            {%- endif -%}
          {%- endif -%}

          {%- if section.settings.show_secondary_cta -%}
            {%- if section.settings.secondary_cta_text != blank -%}
              <a href="{{ section.settings.secondary_cta_link | default: '#' }}" class="btn btn-ghost">
                {{ section.settings.secondary_cta_text }}
              </a>
            {%- endif -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "shopify-section-hero",
  "settings": [
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Maternity products you need, covered by insurance, delivered to your door</p>" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Ardent simplifies the whole process — from checking your coverage to doorstep delivery — so you can focus on your baby." },

    { "type": "header", "content": "Show / hide elements" },
    { "type": "checkbox", "id": "show_heading", "label": "Show heading", "default": true },
    { "type": "checkbox", "id": "show_subheading", "label": "Show subheading", "default": true },
    { "type": "checkbox", "id": "show_primary_cta", "label": "Show primary button", "default": true },
    { "type": "checkbox", "id": "show_secondary_cta", "label": "Show secondary button", "default": true },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_x", "label": "Padding left / right", "min": 0, "max": 96, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_top", "label": "Margin top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_bottom", "label": "Margin bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },

    { "type": "header", "content": "Overlay (over background image)" },
    { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 40 },

    { "type": "header", "content": "Text colors" },
    { "type": "color", "id": "heading_color", "label": "Heading", "default": "#ffffff" },
    { "type": "color", "id": "sub_color", "label": "Subheading", "default": "#ffffff" },

    { "type": "header", "content": "Primary CTA" },
    { "type": "text", "id": "primary_cta_text", "label": "Primary button text", "default": "Check Your Insurance Coverage" },
    { "type": "url", "id": "primary_cta_link", "label": "Primary button link" },
    { "type": "color", "id": "primary_btn_bg", "label": "Background", "default": "#e14e6b" },
    { "type": "color", "id": "primary_btn_text", "label": "Text", "default": "#ffffff" },
    { "type": "color", "id": "primary_btn_border", "label": "Border", "default": "#e14e6b" },

    { "type": "header", "content": "Secondary CTA" },
    { "type": "text", "id": "secondary_cta_text", "label": "Secondary button text", "default": "Shop Products" },
    { "type": "url", "id": "secondary_cta_link", "label": "Secondary button link" },
    { "type": "color", "id": "secondary_btn_text", "label": "Text", "default": "#ffffff" },
    { "type": "color", "id": "secondary_btn_border", "label": "Border", "default": "#ffffff" }
  ],
  "presets": [
    { "name": "Hero Banner" }
  ]
}
{% endschema %}
