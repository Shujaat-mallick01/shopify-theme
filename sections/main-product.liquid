{% comment %}
  Section: Main Product
  File: sections/main-product.liquid
{% endcomment %}

<section class="product-main">
  <div class="container product-grid">

    <div class="product-media">
      {%- if product.featured_image != blank -%}
        {{ product.featured_image | image_url: width: 1200 | image_tag: alt: product.title, loading: 'eager', class: 'product-main-image' }}
      {%- endif -%}

      {%- if product.images.size > 1 -%}
        <div class="product-thumbs">
          {%- for image in product.images -%}
            {{ image | image_url: width: 200 | image_tag: alt: product.title, loading: 'lazy', class: 'product-thumb' }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <div class="product-info">
      <h1 class="product-title">{{ product.title }}</h1>
      <p class="product-price">{{ product.price | money }}</p>

      <div class="product-description rte">
        {{ product.description }}
      </div>

      {%- form 'product', product, class: 'product-form' -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        {%- if product.variants.size > 1 -%}
          <div class="product-variants">
            {%- for option in product.options_with_values -%}
              <label>
                <span>{{ option.name }}</span>
                <select name="options[{{ option.name }}]">
                  {%- for value in option.values -%}
                    <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                  {%- endfor -%}
                </select>
              </label>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <button type="submit" name="add" class="btn btn-primary product-add"
          {%- unless product.selected_or_first_available_variant.available %} disabled{% endunless -%}>
          {%- if product.selected_or_first_available_variant.available -%}
            Add to cart
          {%- else -%}
            Sold out
          {%- endif -%}
        </button>
      {%- endform -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "settings": []
}
{% endschema %}
