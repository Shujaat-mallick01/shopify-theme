{% comment %}
  Section: Products List (4-up product grid with title + "View all" button)
  File: sections/products-list.liquid
  Figma: "Product / 3"
  All colors are editor-controlled with sane fallbacks.
{% endcomment %}

{%- liquid
  assign pad_top = section.settings.padding_top | default: 112
  assign pad_bottom = section.settings.padding_bottom | default: 112
  assign pad_x = section.settings.padding_x | default: 64
  assign margin_top = section.settings.margin_top | default: 0
  assign margin_bottom = section.settings.margin_bottom | default: 0
-%}

<section class="shop-section" style="
  --shop-bg: {{ section.settings.background_color | default: '#ffffff' }};
  --shop-eyebrow-color: {{ section.settings.eyebrow_color | default: '#000000' }};
  --shop-heading-color: {{ section.settings.heading_color | default: '#000000' }};
  --shop-text-color: {{ section.settings.text_color | default: '#000000' }};
  --shop-product-name: {{ section.settings.product_name_color | default: '#000000' }};
  --shop-product-variant: {{ section.settings.product_variant_color | default: '#000000' }};
  --shop-status: {{ section.settings.status_label_color | default: '#000000' }};
  --shop-btn-bg: {{ section.settings.btn_bg | default: '#ffffff' }};
  --shop-btn-text: {{ section.settings.btn_text | default: '#000000' }};
  --shop-btn-border: {{ section.settings.btn_border | default: '#000000' }};
  padding: {{ pad_top }}px {{ pad_x }}px {{ pad_bottom }}px;
  margin: {{ margin_top }}px 0 {{ margin_bottom }}px;
">
  <div class="shop-container">

    <div class="shop-title">
      {%- if section.settings.show_eyebrow -%}
        {%- if section.settings.eyebrow != blank -%}
          <p class="shop-eyebrow" data-reveal>{{ section.settings.eyebrow }}</p>
        {%- endif -%}
      {%- endif -%}
      {%- if section.settings.show_heading -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="shop-heading" data-reveal data-reveal-delay="80">{{ section.settings.heading }}</h2>
        {%- endif -%}
      {%- endif -%}
      {%- if section.settings.show_description -%}
        {%- if section.settings.description != blank -%}
          <div class="shop-desc" data-reveal data-reveal-delay="160">{{ section.settings.description }}</div>
        {%- endif -%}
      {%- endif -%}
    </div>

    <div class="shop-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'product' -%}
          {%- assign p_delay = forloop.index0 | times: 80 -%}

          {%- capture product_inner -%}
            <div class="shop-product-image">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 600 | image_tag: alt: block.settings.name, loading: 'lazy' }}
              {%- endif -%}
            </div>

            <div class="shop-product-content">
              <div class="shop-product-header">
                {%- if block.settings.name != blank -%}
                  <p class="shop-product-name">{{ block.settings.name }}</p>
                {%- endif -%}
                {%- if block.settings.variant != blank -%}
                  <p class="shop-product-variant">{{ block.settings.variant }}</p>
                {%- endif -%}
              </div>
              {%- if block.settings.status_label != blank -%}
                <p class="shop-product-status">{{ block.settings.status_label }}</p>
              {%- endif -%}
            </div>
          {%- endcapture -%}

          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="shop-product" data-reveal data-reveal-delay="{{ p_delay }}" {{ block.shopify_attributes }}>
              {{ product_inner }}
            </a>
          {%- else -%}
            <div class="shop-product" data-reveal data-reveal-delay="{{ p_delay }}" {{ block.shopify_attributes }}>
              {{ product_inner }}
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>

  {%- if section.settings.show_button -%}
    {%- if section.settings.button_text != blank -%}
      <div class="shop-actions" data-reveal data-reveal-delay="120">
        <a href="{{ section.settings.button_link | default: '#' }}" class="shop-btn">
          {{ section.settings.button_text }}
        </a>
      </div>
    {%- endif -%}
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Shop Products",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Title" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>From breast pumps, to milk bags and belly bands, we've got you covered.</p>" },
    { "type": "richtext", "id": "description", "label": "Description", "default": "<p>Shop now, or check your insurance coverage.</p><p>Our Maternity Experts simplify the whole process for you.</p>" },

    { "type": "header", "content": "View all button" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "View all" },
    { "type": "url", "id": "button_link", "label": "Button link" },

    { "type": "header", "content": "Show / hide elements" },
    { "type": "checkbox", "id": "show_eyebrow", "label": "Show eyebrow", "default": true },
    { "type": "checkbox", "id": "show_heading", "label": "Show heading", "default": true },
    { "type": "checkbox", "id": "show_description", "label": "Show description", "default": true },
    { "type": "checkbox", "id": "show_button", "label": "Show \"View all\" button", "default": true },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 112 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 112 },
    { "type": "range", "id": "padding_x", "label": "Padding left / right", "min": 0, "max": 96, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "margin_top", "label": "Margin top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_bottom", "label": "Margin bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 0 },

    { "type": "header", "content": "Section colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow", "default": "#000000" },
    { "type": "color", "id": "heading_color", "label": "Heading", "default": "#000000" },
    { "type": "color", "id": "text_color", "label": "Description", "default": "#000000" },

    { "type": "header", "content": "Product card colors" },
    { "type": "color", "id": "product_name_color", "label": "Product name", "default": "#000000" },
    { "type": "color", "id": "product_variant_color", "label": "Variant text", "default": "#000000" },
    { "type": "color", "id": "status_label_color", "label": "Status label (e.g. \"Covered\")", "default": "#000000" },

    { "type": "header", "content": "Button colors" },
    { "type": "color", "id": "btn_bg", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "btn_text", "label": "Text", "default": "#000000" },
    { "type": "color", "id": "btn_border", "label": "Border", "default": "#000000" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "name", "label": "Product name", "default": "Product name" },
        { "type": "text", "id": "variant", "label": "Variant / subtitle", "default": "Electric" },
        { "type": "text", "id": "status_label", "label": "Status label", "default": "Covered" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Shop Products",
      "blocks": [
        { "type": "product", "settings": { "name": "Spectra S1", "variant": "Electric" } },
        { "type": "product", "settings": { "name": "Medela Pump", "variant": "Electric" } },
        { "type": "product", "settings": { "name": "Lansinoh Manual", "variant": "Manual" } },
        { "type": "product", "settings": { "name": "Philips Avent", "variant": "Electric" } },
        { "type": "product", "settings": { "name": "Storage bags", "variant": "Pack of 50" } },
        { "type": "product", "settings": { "name": "Belly band", "variant": "One size" } },
        { "type": "product", "settings": { "name": "Nursing pads", "variant": "Reusable" } },
        { "type": "product", "settings": { "name": "Maternity pillow", "variant": "Full body" } }
      ]
    }
  ]
}
{% endschema %}
