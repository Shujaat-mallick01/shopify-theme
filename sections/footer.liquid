{% comment %}
  Section: Footer (Footer3 — white footer, brand left + link lists right, divider, credits row)
  File: sections/footer.liquid
{% endcomment %}

<footer class="site-footer">
  <div class="footer-inner">

    <div class="footer-content">

      {%- comment -%} Brand column {%- endcomment -%}
      <div class="footer-brand">
        <div class="footer-logo">
          {%- if section.settings.logo != blank -%}
            {{ section.settings.logo | image_url: width: 200 | image_tag: alt: shop.name, loading: 'lazy', class: 'footer-logo-img' }}
          {%- else -%}
            <span class="footer-logo-text">{{ section.settings.logo_text | default: 'Logo' }}</span>
          {%- endif -%}
        </div>

        <div class="footer-info">
          {%- if section.settings.address != blank -%}
            <div class="footer-address">{{ section.settings.address }}</div>
          {%- endif -%}

          {%- if section.settings.phone != blank or section.settings.email != blank -%}
            <div class="footer-contact">
              <p class="footer-contact-label">Phone</p>
              <div class="footer-contact-list">
                {%- if section.settings.phone != blank -%}
                  <a href="tel:{{ section.settings.phone | replace: ' ', '' | replace: '-', '' }}" class="footer-contact-link">{{ section.settings.phone }}</a>
                {%- endif -%}
                {%- if section.settings.email != blank -%}
                  <a href="mailto:{{ section.settings.email }}" class="footer-contact-link">{{ section.settings.email }}</a>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </div>

        <div class="footer-socials">
          {%- if section.settings.facebook != blank -%}
            <a href="{{ section.settings.facebook }}" aria-label="Facebook" class="footer-social">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="#000" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M13.5 21.95v-7.4h2.5l.4-2.9h-2.9V9.8c0-.84.23-1.4 1.43-1.4H16.5V5.83a20.4 20.4 0 0 0-2.22-.11c-2.2 0-3.7 1.34-3.7 3.8v2.13H8v2.9h2.58v7.4a10 10 0 1 1 2.92 0z"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.instagram != blank -%}
            <a href="{{ section.settings.instagram }}" aria-label="Instagram" class="footer-social">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="#000" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M12 3.6c2.7 0 3 0 4.1.07 1 .05 1.5.21 1.86.35.46.18.8.4 1.15.75.35.35.57.69.75 1.15.14.36.3.86.35 1.86C20.4 8.9 20.4 9.2 20.4 12s0 3-.07 4.1c-.05 1-.21 1.5-.35 1.86-.18.46-.4.8-.75 1.15-.35.35-.69.57-1.15.75-.36.14-.86.3-1.86.35-1.05.07-1.36.07-4.1.07s-3 0-4.1-.07c-1-.05-1.5-.21-1.86-.35a3.07 3.07 0 0 1-1.15-.75 3.07 3.07 0 0 1-.75-1.15c-.14-.36-.3-.86-.35-1.86C3.6 15.1 3.6 14.8 3.6 12s0-3 .07-4.1c.05-1 .21-1.5.35-1.86.18-.46.4-.8.75-1.15.35-.35.69-.57 1.15-.75.36-.14.86-.3 1.86-.35C8.9 3.6 9.2 3.6 12 3.6zM12 2c-2.7 0-3 0-4.1.07-1.1.05-1.85.22-2.5.47A5 5 0 0 0 3.54 3.54 5 5 0 0 0 2.54 5.4c-.25.65-.42 1.4-.47 2.5C2 8.97 2 9.27 2 12s0 3 .07 4.1c.05 1.1.22 1.85.47 2.5a5 5 0 0 0 1.18 1.85 5 5 0 0 0 1.85 1.18c.65.25 1.4.42 2.5.47C8.97 22 9.27 22 12 22s3 0 4.1-.07c1.1-.05 1.85-.22 2.5-.47a5.16 5.16 0 0 0 3.03-3.03c.25-.65.42-1.4.47-2.5.07-1.1.07-1.43.07-4.1s0-3-.07-4.1c-.05-1.1-.22-1.85-.47-2.5a5 5 0 0 0-1.18-1.85 5 5 0 0 0-1.85-1.18c-.65-.25-1.4-.42-2.5-.47C15.03 2 14.73 2 12 2zm0 4.86A5.14 5.14 0 1 0 17.14 12 5.15 5.15 0 0 0 12 6.86zm0 8.47A3.33 3.33 0 1 1 15.33 12 3.33 3.33 0 0 1 12 15.33zm5.34-9.88a1.2 1.2 0 1 0 1.2 1.2 1.2 1.2 0 0 0-1.2-1.2z"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.twitter != blank -%}
            <a href="{{ section.settings.twitter }}" aria-label="X (Twitter)" class="footer-social">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="#000" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25h6.829l4.713 6.231 5.448-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.linkedin != blank -%}
            <a href="{{ section.settings.linkedin }}" aria-label="LinkedIn" class="footer-social">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="#000" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.04a3.74 3.74 0 0 1 3.37-1.85c3.6 0 4.27 2.37 4.27 5.46zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56zM22.22 0H1.77A1.75 1.75 0 0 0 0 1.73v20.54A1.75 1.75 0 0 0 1.77 24h20.45A1.75 1.75 0 0 0 24 22.27V1.73A1.75 1.75 0 0 0 22.22 0z"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.youtube != blank -%}
            <a href="{{ section.settings.youtube }}" aria-label="YouTube" class="footer-social">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="#000" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M23.5 6.2a3 3 0 0 0-2.12-2.13C19.5 3.55 12 3.55 12 3.55s-7.5 0-9.38.52A3 3 0 0 0 .5 6.2C0 8.08 0 12 0 12s0 3.92.5 5.8a3 3 0 0 0 2.12 2.13C4.5 20.45 12 20.45 12 20.45s7.5 0 9.38-.52a3 3 0 0 0 2.12-2.13C24 15.92 24 12 24 12s0-3.92-.5-5.8zM9.6 15.57V8.43L15.82 12z"/>
              </svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Link columns {%- endcomment -%}
      <div class="footer-links">
        {%- for block in section.blocks -%}
          {%- if block.type == 'link_column' -%}
            <div class="footer-link-list" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <a href="{{ block.settings.heading_link | default: '#' }}" class="footer-link">{{ block.settings.heading }}</a>
              {%- endif -%}
              {%- for i in (1..6) -%}
                {%- assign label_key = 'link_' | append: i | append: '_label' -%}
                {%- assign url_key   = 'link_' | append: i | append: '_url' -%}
                {%- assign label = block.settings[label_key] -%}
                {%- assign url   = block.settings[url_key] -%}
                {%- if label != blank -%}
                  <a href="{{ url | default: '#' }}" class="footer-link">{{ label }}</a>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>

    <div class="footer-credits">
      <hr class="footer-divider" aria-hidden="true">
      <div class="footer-credits-row">
        <p class="footer-copyright">{{ section.settings.copyright | default: '© 2025 Ardent Maternity. All rights reserved.' }}</p>
        <div class="footer-legal">
          {%- if section.settings.legal_1_label != blank -%}
            <a href="{{ section.settings.legal_1_link | default: '#' }}">{{ section.settings.legal_1_label }}</a>
          {%- endif -%}
          {%- if section.settings.legal_2_label != blank -%}
            <a href="{{ section.settings.legal_2_link | default: '#' }}">{{ section.settings.legal_2_label }}</a>
          {%- endif -%}
          {%- if section.settings.legal_3_label != blank -%}
            <a href="{{ section.settings.legal_3_link | default: '#' }}">{{ section.settings.legal_3_label }}</a>
          {%- endif -%}
        </div>
      </div>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "div",
  "settings": [
    { "type": "header", "content": "Brand" },
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "text", "id": "logo_text", "label": "Logo text (fallback)", "default": "Logo" },
    { "type": "richtext", "id": "address", "label": "Address", "default": "<p><strong>Brooklyn</strong><br>Ardent Maternity, Brooklyn, New York</p>" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "1-844-923-7356" },
    { "type": "text", "id": "email", "label": "Email", "default": "hello@ardentmaternity.com" },

    { "type": "header", "content": "Social Links" },
    { "type": "url", "id": "facebook", "label": "Facebook URL" },
    { "type": "url", "id": "instagram", "label": "Instagram URL" },
    { "type": "url", "id": "twitter", "label": "X (Twitter) URL" },
    { "type": "url", "id": "linkedin", "label": "LinkedIn URL" },
    { "type": "url", "id": "youtube", "label": "YouTube URL" },

    { "type": "header", "content": "Footer Bottom" },
    { "type": "text", "id": "copyright", "label": "Copyright", "default": "© 2025 Ardent Maternity. All rights reserved." },

    { "type": "text", "id": "legal_1_label", "label": "Legal link 1 text", "default": "Terms of Service" },
    { "type": "url", "id": "legal_1_link", "label": "Legal link 1 URL" },
    { "type": "text", "id": "legal_2_label", "label": "Legal link 2 text", "default": "Privacy Policy" },
    { "type": "url", "id": "legal_2_link", "label": "Legal link 2 URL" },
    { "type": "text", "id": "legal_3_label", "label": "Legal link 3 text", "default": "Cookies Settings" },
    { "type": "url", "id": "legal_3_link", "label": "Legal link 3 URL" }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link Column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading (rendered as first link)" },
        { "type": "url",  "id": "heading_link", "label": "Heading link URL" },
        { "type": "text", "id": "link_1_label", "label": "Link 1 label" },
        { "type": "url",  "id": "link_1_url",   "label": "Link 1 URL" },
        { "type": "text", "id": "link_2_label", "label": "Link 2 label" },
        { "type": "url",  "id": "link_2_url",   "label": "Link 2 URL" },
        { "type": "text", "id": "link_3_label", "label": "Link 3 label" },
        { "type": "url",  "id": "link_3_url",   "label": "Link 3 URL" },
        { "type": "text", "id": "link_4_label", "label": "Link 4 label" },
        { "type": "url",  "id": "link_4_url",   "label": "Link 4 URL" },
        { "type": "text", "id": "link_5_label", "label": "Link 5 label" },
        { "type": "url",  "id": "link_5_url",   "label": "Link 5 URL" },
        { "type": "text", "id": "link_6_label", "label": "Link 6 label" },
        { "type": "url",  "id": "link_6_url",   "label": "Link 6 URL" }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_column",
        "settings": {
          "heading": "Check Insurance",
          "link_1_label": "Shop Products",
          "link_2_label": "Healthcare Providers",
          "link_3_label": "About us",
          "link_4_label": "How it works"
        }
      },
      {
        "type": "link_column",
        "settings": {
          "heading": "Breast pumps",
          "link_1_label": "Milk storage",
          "link_2_label": "Maternity supports",
          "link_3_label": "Postpartum essentials"
        }
      }
    ]
  }
}
{% endschema %}
